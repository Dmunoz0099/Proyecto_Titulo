# ============================================================
#  Variables de entorno del BACKEND (server)
#  Copia este archivo como ".env" y rellena los valores reales.
#  NUNCA subas el archivo .env real al repositorio.
# ============================================================

# --- Puerto donde escucha Express ---
PORT=4000

# --- Entorno de ejecución (development | production) ---
NODE_ENV=development

# ============================================================
#  CONEXIÓN A SUPABASE (PostgreSQL)
# ============================================================
# DATABASE_URL  -> conexión que usa la APP en tiempo de ejecución.
#                  Recomendado usar el "Connection Pooler" de Supabase
#                  (puerto 6543) con el parámetro pgbouncer=true.
# DIRECT_URL    -> conexión DIRECTA (puerto 5432) que Prisma usa SOLO
#                  para las migraciones (prisma migrate). El pooler no
#                  soporta migraciones, por eso se separan.
#
# Reemplaza:
#   [PASSWORD]  -> la contraseña de tu base de datos.
#   [PROJECT-REF] -> el identificador de tu proyecto Supabase.
#   [REGION]    -> la región del pooler (ej: aws-0-us-east-1).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# ============================================================
#  AUTENTICACIÓN (JWT)
# ============================================================
# Secreto para firmar los tokens. Usa una cadena larga y aleatoria.
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio"
# Tiempo de expiración del token (ej: 1d, 12h, 7d).
JWT_EXPIRES_IN="1d"

# ============================================================
#  CORS
# ============================================================
# Origen del frontend autorizado a consumir la API.
CORS_ORIGIN="http://localhost:8099"
